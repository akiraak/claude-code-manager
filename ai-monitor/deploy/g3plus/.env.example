# ai-monitor (server モード) の環境変数。
# 最終配置: /home/ubuntu/g3plus-ops/ai-monitor/.env （gitignore）。本 .env.example は追跡する。
# compose は env_file でこれをコンテナへ注入する。

# === 必須 ===
# 端末別 ingest トークン（カンマ区切り）。各値 16 文字以上の URL-safe 文字列。
# 未設定 / 16 文字未満が混じると起動失敗（fail-fast）。
# 生成: openssl rand -base64 32 | tr -d '+/=' | head -c 32
# 端末 (WSL2 / Mac) ごとに 1 つ発行し、クライアント側 CCM_CLIENT_TOKEN に同じ値を入れる。
# クライアントの CCM_CLIENT_TOKEN(単数) と区別するため server 側は CCM_INGEST_TOKENS(複数)。
# (旧名 CCM_CLIENT_TOKENS も後方互換で読まれるが非推奨)
# 例: CCM_INGEST_TOKENS=tok_wsl2_xxxxxxxxxxxxxxxx,tok_mac_yyyyyyyyyyyyyyyy
CCM_INGEST_TOKENS=

# === 任意 ===
# ブラウザ UI の許可オリジン（カンマ区切り）。未設定なら CORS ヘッダを付けない。
# 公開ドメインを設定する。例: https://ccm.chobi.me
CCM_CORS_ORIGIN=https://ccm.chobi.me

# ペルソナ短文（ちょビ口調）+ カード要約に使う Anthropic キー。未設定なら fallback テンプレで動作。
ANTHROPIC_API_KEY=

# Gemini TTS キー。未設定なら音声なし（テキストのみ utterance）。
GEMINI_API_KEY=

# TTS モデル。既定 gemini-2.5-flash-preview-tts（本番で高品質にするなら gemini-2.5-pro-preview-tts も可）。
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# TTS プロバイダ切替。gemini（既定）/ none（音声を完全に止めテキストのみ）。
CCM_VOICE_TTS_PROVIDER=gemini

# タイムゾーン（ログ等）。
TZ=Asia/Tokyo
