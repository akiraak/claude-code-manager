# claude-code-manager の環境変数サンプル。`.env` にコピーして値を埋める。
# `.env` は .gitignore 済み。大半は `ai-monitor` 起動時に dotenv で読まれる。
# 例外: 待受ポート/ホスト (VIBEBOARD_PORT / CCM_SERVER_HOST / CCM_SERVER_PORT / CCM_CLIENT_DASH_PORT) は dotenv ではなく
# 起動スクリプト run-ai-monitor.sh / run-ai-monitor-client.sh が .env から読む (直接 node 起動時は --host / --port で渡す)。
# 必要な変数は --mode で変わる (local: 要約キーのみ任意 / server / client)。1 つの `.env` に
# 動かすモードの分だけ書けばよい (使わないモードの変数は無くてよい)。

# ───────────────────────── 共通 (local / server / client) ─────────────────────────

# ダッシュボードの AI 要約、および server モードのペルソナ文生成 (Haiku) に使う Claude API キー。
# 未設定なら要約は黙って無効化 (カードに「(要約: API キー未設定)」)、ペルソナ文は定型テンプレ (fallback) になる。
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ───────────────────────── server モード (--mode server) ─────────────────────────
# 公開アグリゲータ。端末が push する snapshot / voice-event を受けて集約・音声生成・配信する。

# 待受ホスト/ポート (run-ai-monitor.sh が .env から読む。直接 node 起動時は --host / --port)。
# 既定 127.0.0.1:8190 = ローカルのみ。同一 LAN の他端末から接続させるなら CCM_SERVER_HOST=0.0.0.0。
CCM_SERVER_HOST=127.0.0.1
CCM_SERVER_PORT=8190

# ingest (/api/ingest/*) を許可する端末別 Bearer トークン (カンマ区切り・各 16 文字以上)。
# 必須: 未設定/短すぎは起動拒否 (fail-fast)。下はダミー。端末ごとに openssl rand -base64 32 で生成して置き換える。
# クライアントの CCM_CLIENT_TOKEN (単数) と紛らわしくないよう server 側は CCM_INGEST_TOKENS (複数)。
# 各端末の CCM_CLIENT_TOKEN を、ここにカンマ区切りで全部列挙する。
# (旧名 CCM_CLIENT_TOKENS も後方互換で読まれるが非推奨。)
CCM_INGEST_TOKENS=CHANGE_ME_wsl2_0123456789abcdef,CHANGE_ME_mac_0123456789abcdef

# UI/閲覧系の CORS 許可オリジン (カンマ区切り)。未設定なら CORS ヘッダを付けない。
# AI Monitor タブ (vibeboard :8180) が server (:8190) へブラウザ fetch/SSE するため、vibeboard の
# オリジンを許可する必要がある。run-ai-monitor.sh は未設定なら loopback 既定を自動許可するので、
# ローカル利用なら通常この行は不要。LAN 越し/別ホストで開くならそのオリジンをここに列挙する。
CCM_CORS_ORIGIN=http://localhost:8180,http://127.0.0.1:8180,http://localhost:8190,http://127.0.0.1:8190

# 進捗音声 (TTS) に使う Gemini API キー。未設定なら音声は作られず (テキストのみ utterance)、サーバは落ちない。
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TTS プロバイダ。既定 gemini。none / null で TTS を無効化 (テキストのみ utterance)。
CCM_VOICE_TTS_PROVIDER=gemini

# 読み上げる種別 (server)。csv・既定 completed,awaiting,progress。許可は awaiting/completed/progress のみ
# (started は常に無音)。これは生成の【絶対上限=天井】で、UI のチェックはこの内側でしか効かない。
# 頻度を下げたいとき種別を絞る。例: progress(2分間隔の途中経過)を 0% にする:
#   CCM_VOICE_SPOKEN_KINDS=completed,awaiting
# 未設定/空/不正は既定にフォールバック (typo で全無音にならない)。
CCM_VOICE_SPOKEN_KINDS=completed,awaiting,progress

# UI ゲーティング (server)。on (既定) で、ダッシュボードの種別チェック + 🔊 ON/OFF により
# server 側の生成 (Haiku 台本 + Gemini TTS) そのものを抑止する (誰も聴いていない種別/時間帯のコスト削減・
# 即時反映)。生成種別 = CCM_VOICE_SPOKEN_KINDS(天井) ∩ ∪{接続中 🔊ON viewer の希望種別}。
# 🔊ON の viewer がゼロ → 無音 (生成しない)。off で従来の env 静的生成 (天井の種別を常時生成) へロールバック。
CCM_VOICE_UI_GATING=on

# Gemini TTS モデル。既定 gemini-2.5-flash-preview-tts (本番は gemini-2.5-pro-preview-tts も可)。
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# 注: UI / 音声の閲覧認証は Cloudflare Access (email OTP) をインフラ層で掛ける方針 (Phase 7)。
#     /api/voice/audio/:id は推測困難な乱数 id を capability とし、本番は Access 配下に置く。
#     ペルソナの声 (Leda) / 口調 / ルールは env ではなく ai-monitor/voice-persona.json で編集する。

# ───────────────────────── client モード (--mode client) ─────────────────────────
# 各端末で動かし、ローカル FS を pull しつつ公開サーバへ push する uplink。

# 送信先 (公開サーバ)。非 dryrun では必須・http(s):// で始まること。
CCM_SERVER_URL=https://ccm.example.com

# クライアント自身のローカルダッシュボード待受ポート (run-ai-monitor-client.sh が .env から読む)。既定 8191。
CCM_CLIENT_DASH_PORT=8191

# この端末の Bearer トークン (server 側 CCM_INGEST_TOKENS のいずれか・16 文字以上)。非 dryrun では必須。
CCM_CLIENT_TOKEN=CHANGE_ME_wsl2_0123456789abcdef

# 集約ストアの突き合わせキー (clientId)。未設定なら hostname。
CCM_CLIENT_LABEL=wsl2-akira

# ミラー対象 allowlist (カンマ区切り・cwd basename / projectDir / cwd の完全一致)。
# 未設定なら全プロジェクトをミラー対象にする。外部へ出したくないものがあるときだけ絞り込む。
CCM_MIRROR_PROJECTS=

# 1 / true で実送信せずログのみ (CCM_SERVER_URL / CCM_CLIENT_TOKEN 無しでも動かせる)。
CCM_DRYRUN=

# snapshot tick 間隔 (ms)。既定 4000 (最小 1000)。
CCM_CLIENT_INTERVAL_MS=4000

# 「長時間実行」とみなして途中経過を発話し始めるまで (ms)。既定 120000。
CCM_PROGRESS_AFTER_MS=120000

# 途中経過を繰り返す間隔 (ms)。既定 120000。
CCM_PROGRESS_EVERY_MS=120000
